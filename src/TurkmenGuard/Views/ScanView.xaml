<UserControl x:Class="TurkmenGuard.Views.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="{Binding Title}" Style="{StaticResource TgPageTitle}" Margin="0,0,0,24"/>

            <UniformGrid Columns="2" Margin="0,0,0,24">
                <Button Margin="0,0,8,0" Command="{Binding QuickScanCommand}"
                        Style="{StaticResource TgPrimaryButton}" Content="{Binding QuickScanLabel}"/>
                <Button Margin="8,0,0,0" Command="{Binding FullScanCommand}"
                        Style="{StaticResource TgOutlineButton}" Content="{Binding FullScanLabel}"/>
            </UniformGrid>

            <!-- Live threat feed: RT, process monitor, scans -->
            <materialDesign:Card Style="{StaticResource TgCard}"
                               Visibility="{Binding HasLiveThreats, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding AllThreatsLabel}" Style="{StaticResource TgSectionTitle}" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding LiveThreats}" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False" MaxHeight="280"
                              Style="{StaticResource TgDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding DataContext.ColFile, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Binding="{Binding FilePath}" Width="*"/>
                            <DataGridTextColumn Header="{Binding DataContext.ColThreat, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Binding="{Binding ThreatName}" Width="120"/>
                            <DataGridTextColumn Header="{Binding DataContext.ColSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Binding="{Binding Source}" Width="90"/>
                            <DataGridTextColumn Header="{Binding DataContext.ColRisk, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Binding="{Binding RiskLabel}" Width="90"/>
                            <DataGridTextColumn Header="{Binding DataContext.ColAction, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Binding="{Binding ActionTaken}" Width="100"/>
                            <DataGridTemplateColumn Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding DataContext.QuarantineLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Command="{Binding DataContext.QuarantineThreatCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignFlatButton}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Style="{StaticResource TgCard}">
                <StackPanel>
                    <TextBlock Text="{Binding FileScanLabel}" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="..." Command="{Binding BrowseFileCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"/>
                    </Grid>
                    <Button Margin="0,12,0,0" Height="40"
                            Command="{Binding FileScanCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{DynamicResource BrandGreenBrush}"
                            Content="{Binding StartLabel}"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Padding="20" Margin="0,0,0,16"
                                 Background="{DynamicResource CardBackgroundBrush}"
                                 UniformCornerRadius="8">
                <StackPanel>
                    <TextBlock Text="{Binding CustomScanLabel}" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding CustomPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="..." Command="{Binding BrowseFolderCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"/>
                    </Grid>
                    <Button Margin="0,12,0,0" Height="40"
                            Command="{Binding CustomScanCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{DynamicResource BrandGreenBrush}"
                            Content="{Binding StartLabel}"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Padding="20" Margin="0,0,0,16"
                                 Background="{DynamicResource CardBackgroundBrush}"
                                 UniformCornerRadius="8">
                <StackPanel>
                    <TextBlock Text="{Binding ProgressText}"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <ProgressBar Value="{Binding ProgressValue}" Height="8" Maximum="100"
                                 IsIndeterminate="{Binding IsIndeterminate}"/>
                    <TextBlock Text="{Binding ThreatsLabel}" Margin="0,12,0,0"
                               Foreground="{DynamicResource BrandGreenBrush}"/>
                    <Button Margin="0,12,0,0" HorizontalAlignment="Left"
                            Command="{Binding CancelScanCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Content="{Binding CancelLabel}"
                            Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Padding="20"
                                 Background="{DynamicResource CardBackgroundBrush}"
                                 UniformCornerRadius="8"
                                 Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding ResultsLabel}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SummaryLabel}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,12"
                               FontSize="13"/>

                    <ItemsControl ItemsSource="{Binding ThreatGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Margin="0,0,0,8" IsExpanded="{Binding IsExpanded}"
                                          Background="Transparent"
                                          Foreground="{DynamicResource TextPrimaryBrush}">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="8" Height="8" CornerRadius="4" Margin="0,0,8,0"
                                                    Background="{Binding AccentBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Hint}" Margin="12,0,0,0"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Expander.Header>
                                    <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                                              IsReadOnly="True" CanUserAddRows="False" MaxHeight="220"
                                              Margin="0,8,0,0"
                                              Background="Transparent"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="{Binding DataContext.ColFile, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                Binding="{Binding FilePath}" Width="*"/>
                                            <DataGridTextColumn Header="{Binding DataContext.ColThreat, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                Binding="{Binding ThreatName}" Width="130"/>
                                            <DataGridTextColumn Header="{Binding DataContext.ColRisk, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                Binding="{Binding RiskLabel}" Width="110"/>
                                            <DataGridTextColumn Header="{Binding DataContext.ColMethod, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                Binding="{Binding Method}" Width="70"/>
                                            <DataGridTemplateColumn Width="110">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding DataContext.QuarantineLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                Command="{Binding DataContext.QuarantineThreatCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Padding="6,2"
                                                                Style="{StaticResource MaterialDesignFlatButton}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
