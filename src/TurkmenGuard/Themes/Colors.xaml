<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================ -->
    <!--  TurkmenGuard v4.0 — Design System                           -->
    <!--  Strict dark navy + emerald green accent. 8px spacing grid.  -->
    <!-- ============================================================ -->

    <!-- Brand surface palette (layered dark navy) -->
    <Color x:Key="BrandDarkBlueColor">#0A1428</Color>
    <Color x:Key="SurfaceDeepColor">#0A1428</Color>
    <Color x:Key="SidebarBackgroundColor">#0C1830</Color>
    <Color x:Key="CardBackgroundColor">#122038</Color>
    <Color x:Key="CardHoverBackgroundColor">#162844</Color>

    <!-- Accent: emerald green -->
    <Color x:Key="BrandGreenColor">#22C55E</Color>
    <Color x:Key="AccentGreenColor">#22C55E</Color>
    <Color x:Key="AccentGreenHoverColor">#16A34A</Color>
    <Color x:Key="AccentGreenPressedColor">#15803D</Color>
    <Color x:Key="AccentGreenFaintColor">#1A22C55E</Color>

    <!-- Semantic colors -->
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="DangerHoverColor">#DC2626</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="InfoColor">#60A5FA</Color>
    <Color x:Key="SuccessColor">#22C55E</Color>

    <!-- Text + borders -->
    <Color x:Key="TextPrimaryColor">#E8ECF2</Color>
    <Color x:Key="TextSecondaryColor">#8A9AB0</Color>
    <Color x:Key="TextMutedColor">#5C6B7F</Color>
    <Color x:Key="BorderColor">#1E3454</Color>
    <Color x:Key="BorderStrongColor">#2A4566</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BrandDarkBlueBrush" Color="{StaticResource BrandDarkBlueColor}"/>
    <SolidColorBrush x:Key="SurfaceDeepBrush" Color="{StaticResource SurfaceDeepColor}"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardHoverBackgroundBrush" Color="{StaticResource CardHoverBackgroundColor}"/>

    <SolidColorBrush x:Key="BrandGreenBrush" Color="{StaticResource BrandGreenColor}"/>
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreenColor}"/>
    <SolidColorBrush x:Key="AccentGreenHoverBrush" Color="{StaticResource AccentGreenHoverColor}"/>
    <SolidColorBrush x:Key="AccentGreenFaintBrush" Color="{StaticResource AccentGreenFaintColor}"/>

    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource DangerHoverColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}"/>

    <!-- Typography -->
    <FontFamily x:Key="AppFont">Segoe UI</FontFamily>

    <!-- Spacing grid (8px base) -->
    <sys:Double x:Key="CardPadding">24</sys:Double>
    <sys:Double x:Key="CardGap">16</sys:Double>
    <sys:Double x:Key="HeaderGap">24</sys:Double>
    <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="ButtonCornerRadius">6</CornerRadius>
</ResourceDictionary>
