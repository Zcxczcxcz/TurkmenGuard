<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================ -->
    <!--  TurkmenGuard v5.0 — Design System                          -->
    <!--  Deep navy surfaces · emerald accent · soft glows           -->
    <!--  8px spacing grid · strict typographic hierarchy            -->
    <!-- ============================================================ -->

    <!-- ===== Surface palette (layered depth) ===== -->
    <Color x:Key="AppBackgroundColor">#070C18</Color>
    <Color x:Key="BrandDarkBlueColor">#070C18</Color>
    <Color x:Key="SurfaceDeepColor">#070C18</Color>
    <Color x:Key="SidebarBackgroundColor">#0A1120</Color>
    <Color x:Key="SidebarAccentColor">#0D1830</Color>
    <Color x:Key="CardBackgroundColor">#101A2E</Color>
    <Color x:Key="CardHoverBackgroundColor">#15233D</Color>
    <Color x:Key="CardSunkenColor">#0C1424</Color>
    <Color x:Key="PanelBackgroundColor">#0E1828</Color>
    <Color x:Key="HeaderBackgroundColor">#0B1424</Color>

    <!-- ===== Accent: emerald ===== -->
    <Color x:Key="BrandGreenColor">#22C55E</Color>
    <Color x:Key="AccentGreenColor">#22C55E</Color>
    <Color x:Key="AccentGreenHoverColor">#2BD96B</Color>
    <Color x:Key="AccentGreenPressedColor">#15A34A</Color>
    <Color x:Key="AccentGreenFaintColor">#1A22C55E</Color>
    <Color x:Key="AccentGreenGlowColor">#3322C55E</Color>

    <!-- ===== Semantic colors ===== -->
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="DangerHoverColor">#F2626A</Color>
    <Color x:Key="DangerFaintColor">#1AEF4444</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="WarningFaintColor">#1AF59E0B</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>
    <Color x:Key="InfoFaintColor">#1A3B82F6</Color>
    <Color x:Key="SuccessColor">#22C55E</Color>
    <Color x:Key="CriticalColor">#DC2626</Color>

    <!-- ===== Text + borders ===== -->
    <Color x:Key="TextPrimaryColor">#EDF1F7</Color>
    <Color x:Key="TextSecondaryColor">#9CABC2</Color>
    <Color x:Key="TextMutedColor">#5C6B82</Color>
    <Color x:Key="TextOnAccentColor">#04130A</Color>
    <Color x:Key="BorderColor">#1B2B45</Color>
    <Color x:Key="BorderStrongColor">#2A4566</Color>
    <Color x:Key="BorderAccentColor">#1F3A28</Color>

    <!-- ===== Brushes ===== -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}"/>
    <SolidColorBrush x:Key="BrandDarkBlueBrush" Color="{StaticResource BrandDarkBlueColor}"/>
    <SolidColorBrush x:Key="SurfaceDeepBrush" Color="{StaticResource SurfaceDeepColor}"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}"/>
    <SolidColorBrush x:Key="SidebarAccentBrush" Color="{StaticResource SidebarAccentColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardHoverBackgroundBrush" Color="{StaticResource CardHoverBackgroundColor}"/>
    <SolidColorBrush x:Key="CardSunkenBrush" Color="{StaticResource CardSunkenColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackgroundColor}"/>

    <SolidColorBrush x:Key="BrandGreenBrush" Color="{StaticResource BrandGreenColor}"/>
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreenColor}"/>
    <SolidColorBrush x:Key="AccentGreenHoverBrush" Color="{StaticResource AccentGreenHoverColor}"/>
    <SolidColorBrush x:Key="AccentGreenPressedBrush" Color="{StaticResource AccentGreenPressedColor}"/>
    <SolidColorBrush x:Key="AccentGreenFaintBrush" Color="{StaticResource AccentGreenFaintColor}"/>
    <SolidColorBrush x:Key="AccentGreenGlowBrush" Color="{StaticResource AccentGreenGlowColor}"/>

    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource DangerHoverColor}"/>
    <SolidColorBrush x:Key="DangerFaintBrush" Color="{StaticResource DangerFaintColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningFaintBrush" Color="{StaticResource WarningFaintColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="InfoFaintBrush" Color="{StaticResource InfoFaintColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="CriticalBrush" Color="{StaticResource CriticalColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccentColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}"/>
    <SolidColorBrush x:Key="BorderAccentBrush" Color="{StaticResource BorderAccentColor}"/>

    <!-- ===== Gradients ===== -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#2BD96B"/>
        <GradientStop Offset="1" Color="#15A34A"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#0F2238"/>
        <GradientStop Offset="1" Color="#0A1626"/>
    </LinearGradientBrush>
    <RadialGradientBrush x:Key="ShieldGlowBrush" GradientOrigin="0.5,0.5">
        <GradientStop Offset="0" Color="#5522C55E"/>
        <GradientStop Offset="0.6" Color="#2222C55E"/>
        <GradientStop Offset="1" Color="#0022C55E"/>
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="DangerGlowBrush" GradientOrigin="0.5,0.5">
        <GradientStop Offset="0" Color="#55EF4444"/>
        <GradientStop Offset="0.6" Color="#22EF4444"/>
        <GradientStop Offset="1" Color="#00EF4444"/>
    </RadialGradientBrush>

    <!-- ===== Typography ===== -->
    <FontFamily x:Key="AppFont">Segoe UI Variable, Segoe UI, Segoe UI Text</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas, Courier New</FontFamily>

    <!-- ===== Spacing grid (8px base) ===== -->
    <!-- Card.Padding expects Thickness; UniformCornerRadius expects double -->
    <Thickness x:Key="CardPadding">24</Thickness>
    <Thickness x:Key="CardPaddingLg">28</Thickness>
    <sys:Double x:Key="CardGap">16</sys:Double>
    <sys:Double x:Key="HeaderGap">24</sys:Double>
    <sys:Double x:Key="SectionGap">20</sys:Double>
    <sys:Double x:Key="CardCornerRadius">12</sys:Double>
    <CornerRadius x:Key="ButtonCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="PillCornerRadius">999</CornerRadius>
    <CornerRadius x:Key="TileCornerRadius">10</CornerRadius>
    <Thickness x:Key="CardBorderThickness">1</Thickness>

    <!-- ===== Elevation shadows (flat + soft glow) ===== -->
    <DropShadowEffect x:Key="CardShadowEffect" Color="#000000" Opacity="0.35" BlurRadius="24"
                      ShadowDepth="0" Direction="0"/>
    <DropShadowEffect x:Key="SoftShadowEffect" Color="#000000" Opacity="0.25" BlurRadius="12"
                      ShadowDepth="2" Direction="270"/>
    <DropShadowEffect x:Key="AccentGlowEffect" Color="#22C55E" Opacity="0.45" BlurRadius="18"
                      ShadowDepth="0" Direction="0"/>
    <DropShadowEffect x:Key="DangerGlowEffect" Color="#EF4444" Opacity="0.4" BlurRadius="16"
                      ShadowDepth="0" Direction="0"/>
    <DropShadowEffect x:Key="DialogShadowEffect" Color="#000000" Opacity="0.55" BlurRadius="40"
                      ShadowDepth="0" Direction="0"/>
</ResourceDictionary>
