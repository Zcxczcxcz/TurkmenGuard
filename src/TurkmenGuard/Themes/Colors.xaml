<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================ -->
    <!--  TurkmenGuard v5.0 — Security Operations design system       -->
    <!--  Dark navy + emerald accent. 8px grid. Layered depth + glow. -->
    <!-- ============================================================ -->

    <!-- ===== Brand surface palette (layered dark navy) ===== -->
    <Color x:Key="BrandDarkBlueColor">#080E1A</Color>
    <Color x:Key="SurfaceDeepColor">#080E1A</Color>
    <Color x:Key="SidebarBackgroundColor">#0F1A2E</Color>
    <Color x:Key="CardBackgroundColor">#162236</Color>
    <Color x:Key="CardHoverBackgroundColor">#1A2B42</Color>
    <Color x:Key="CardElevatedColor">#1C3048</Color>
    <Color x:Key="TileBackgroundColor">#111C2C</Color>

    <!-- ===== Accent: emerald ===== -->
    <Color x:Key="BrandGreenColor">#10B981</Color>
    <Color x:Key="AccentGreenColor">#10B981</Color>
    <Color x:Key="AccentGreenHoverColor">#059669</Color>
    <Color x:Key="AccentGreenPressedColor">#047857</Color>
    <Color x:Key="AccentGreenFaintColor">#1A10B981</Color>
    <Color x:Key="AccentGlowColor">#3310B981</Color>
    <Color x:Key="AccentGlowStrongColor">#5510B981</Color>

    <!-- ===== Score / status ring shades ===== -->
    <Color x:Key="ScoreCriticalColor">#F43F5E</Color>
    <Color x:Key="ScoreWarningColor">#F59E0B</Color>
    <Color x:Key="ScoreGoodColor">#10B981</Color>

    <!-- ===== Semantic colors ===== -->
    <Color x:Key="DangerColor">#F43F5E</Color>
    <Color x:Key="DangerHoverColor">#E11D48</Color>
    <Color x:Key="DangerFaintColor">#1AF43F5E</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="WarningFaintColor">#1AF59E0B</Color>
    <Color x:Key="InfoColor">#38BDF8</Color>
    <Color x:Key="InfoFaintColor">#1A38BDF8</Color>
    <Color x:Key="SuccessColor">#10B981</Color>

    <!-- ===== Text + borders ===== -->
    <Color x:Key="TextPrimaryColor">#F1F5F9</Color>
    <Color x:Key="TextSecondaryColor">#94A3B8</Color>
    <Color x:Key="TextMutedColor">#64748B</Color>
    <Color x:Key="BorderColor">#1E293B</Color>
    <Color x:Key="BorderStrongColor">#334155</Color>
    <Color x:Key="DividerColor">#152338</Color>

    <!-- ===== Brushes ===== -->
    <SolidColorBrush x:Key="BrandDarkBlueBrush" Color="{StaticResource BrandDarkBlueColor}"/>
    <SolidColorBrush x:Key="SurfaceDeepBrush" Color="{StaticResource SurfaceDeepColor}"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardHoverBackgroundBrush" Color="{StaticResource CardHoverBackgroundColor}"/>
    <SolidColorBrush x:Key="CardElevatedBrush" Color="{StaticResource CardElevatedColor}"/>
    <SolidColorBrush x:Key="TileBackgroundBrush" Color="{StaticResource TileBackgroundColor}"/>

    <SolidColorBrush x:Key="BrandGreenBrush" Color="{StaticResource BrandGreenColor}"/>
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreenColor}"/>
    <SolidColorBrush x:Key="AccentGreenHoverBrush" Color="{StaticResource AccentGreenHoverColor}"/>
    <SolidColorBrush x:Key="AccentGreenFaintBrush" Color="{StaticResource AccentGreenFaintColor}"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource AccentGlowColor}"/>
    <SolidColorBrush x:Key="AccentGlowStrongBrush" Color="{StaticResource AccentGlowStrongColor}"/>

    <SolidColorBrush x:Key="ScoreCriticalBrush" Color="{StaticResource ScoreCriticalColor}"/>
    <SolidColorBrush x:Key="ScoreWarningBrush" Color="{StaticResource ScoreWarningColor}"/>
    <SolidColorBrush x:Key="ScoreGoodBrush" Color="{StaticResource ScoreGoodColor}"/>

    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource DangerHoverColor}"/>
    <SolidColorBrush x:Key="DangerFaintBrush" Color="{StaticResource DangerFaintColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningFaintBrush" Color="{StaticResource WarningFaintColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="InfoFaintBrush" Color="{StaticResource InfoFaintColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}"/>

    <!-- ===== Effects ===== -->
    <DropShadowEffect x:Key="CardShadowEffect" Color="#000000" BlurRadius="16" ShadowDepth="0" Opacity="0.35"/>
    <DropShadowEffect x:Key="CardShadow" Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.30"/>
    <DropShadowEffect x:Key="DeepShadow" Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.45"/>
    <DropShadowEffect x:Key="GreenGlow" Color="#10B981" BlurRadius="24" ShadowDepth="0" Opacity="0.45" Direction="0"/>
    <DropShadowEffect x:Key="GreenGlowSoft" Color="#10B981" BlurRadius="36" ShadowDepth="0" Opacity="0.25" Direction="0"/>

    <!-- ===== Typography ===== -->
    <FontFamily x:Key="AppFont">Segoe UI Variable Display, Segoe UI Variable, Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Code, Cascadia Mono, Consolas</FontFamily>

    <!-- ===== Spacing grid (8px base) ===== -->
    <sys:Double x:Key="CardCornerRadius">12</sys:Double>
    <Thickness x:Key="CardPadding">24</Thickness>
    <Thickness x:Key="CardPaddingCompact">18</Thickness>
    <sys:Double x:Key="CardGap">16</sys:Double>
    <sys:Double x:Key="HeaderGap">24</sys:Double>
    <CornerRadius x:Key="ButtonCornerRadius">8</CornerRadius>
    <sys:Double x:Key="TileCornerRadius">10</sys:Double>
    <sys:Double x:Key="PillCornerRadius">999</sys:Double>
</ResourceDictionary>
