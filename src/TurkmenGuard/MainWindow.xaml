<Window x:Class="TurkmenGuard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:services="clr-namespace:TurkmenGuard.Services"
        Title="Türkmen Goragçy"
        Height="780" Width="1200"
        MinHeight="680" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrandDarkBlueBrush}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{StaticResource AppFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Grid.RowSpan="2"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="0,20,0,16">
                <!-- Brand header -->
                <StackPanel DockPanel.Dock="Top" Margin="20,0,20,28">
                    <Border Width="44" Height="44" CornerRadius="10"
                            Background="{StaticResource AccentGreenBrush}" Margin="0,0,0,12">
                        <TextBlock Text="TG" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="White"/>
                    </Border>
                    <TextBlock Text="{x:Static services:LocalizationService.AppTitle}"
                               FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Static services:LocalizationService.BrandSubtitle}"
                               FontSize="11" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Navigation -->
                <ListBox x:Name="NavList"
                         ItemsSource="{Binding NavItems}"
                         SelectedItem="{Binding SelectedNav, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         Margin="8,0"
                         SelectionChanged="NavList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                            <Setter Property="Padding" Value="14,11"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderThickness" Value="3,0,0,0"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="materialDesign:ListBoxItemAssist.ShowSelection" Value="False"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="Background" Value="{DynamicResource CardHoverBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentGreenBrush}"/>
                                    <Setter Property="Background" Value="{StaticResource AccentGreenFaintBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}" FontSize="15" Width="24"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"/>
                                <TextBlock Text="{Binding Title}" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Border Grid.Column="1" Grid.Row="0" Padding="32"
                Background="{DynamicResource BrandDarkBlueBrush}">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>

        <!-- Status bar -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock DockPanel.Dock="Right" Text="{Binding VersionText}"
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                        <Ellipse.Fill>
                            <Binding Path="IsProtectionEnabled" Converter="{StaticResource ProtectionBrushConverter}"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
