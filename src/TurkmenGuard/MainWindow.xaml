<Window x:Class="TurkmenGuard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:services="clr-namespace:TurkmenGuard.Services"
        Title="Türkmen Goragçy"
        Height="800" Width="1240"
        MinHeight="680" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrandDarkBlueBrush}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{StaticResource AppFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Grid.RowSpan="2"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="0,20,0,16">
                <StackPanel DockPanel.Dock="Top" Margin="18,0,18,24">
                    <Border Width="44" Height="44" CornerRadius="10"
                            Background="{DynamicResource AccentGreenBrush}" Margin="0,0,0,12"
                            Effect="{StaticResource CardShadowEffect}">
                        <materialDesign:PackIcon Kind="Shield" Width="24" Height="24"
                                                 Foreground="White" HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{x:Static services:LocalizationService.AppTitle}"
                               FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Static services:LocalizationService.BrandSubtitle}"
                               FontSize="11" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <ListBox x:Name="NavList"
                         ItemsSource="{Binding NavItems}"
                         SelectedItem="{Binding SelectedNav, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         Margin="6,0"
                         SelectionChanged="NavList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource TgNavListBoxItem}"/>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="{Binding IconKind}" Width="20" Height="20"
                                                         Margin="0,0,12,0" VerticalAlignment="Center"
                                                         Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"/>
                                <TextBlock Text="{Binding Title}" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Grid.Row="0" Padding="28,24"
                Background="{DynamicResource BrandDarkBlueBrush}">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>

        <Border Grid.Column="1" Grid.Row="1"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock DockPanel.Dock="Right" Text="{Binding VersionText}"
                           FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                        <Ellipse.Fill>
                            <Binding Path="IsProtectionEnabled" Converter="{StaticResource ProtectionBrushConverter}"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
