<UserControl x:Class="TurkmenGuard.Controls.StatCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <materialDesign:Card Style="{StaticResource TgCard}" Margin="0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Style="{StaticResource TgStatLabel}"/>
                <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Style="{StaticResource TgStatValue}" Margin="0,8,0,0"
                           Foreground="{Binding ValueBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                <TextBlock Text="{Binding Subtitle, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="11" Margin="0,4,0,0"
                           Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
            <materialDesign:PackIcon Grid.Column="1" Kind="{Binding IconKind, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     Width="28" Height="28" VerticalAlignment="Top"
                                     Foreground="{Binding ValueBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     Opacity="0.6"/>
        </Grid>
    </materialDesign:Card>
</UserControl>
